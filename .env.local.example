# Supabase project URL & anon key (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - SERVER ONLY. Never expose to the client / never prefix with NEXT_PUBLIC.
# Used by server routes to create rooms & guest users bypassing RLS in a controlled way.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
